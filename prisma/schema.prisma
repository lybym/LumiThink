generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RawEventType {
  PARENT_UPLOAD
  KID_INTERACTION_TRACE
  LLM_EVALUATION
  PROFILE_SNAPSHOT
}

model Parent {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  children  Child[]
}

model Child {
  id        String   @id @default(cuid())
  parentId  String
  name      String
  age       Int
  createdAt DateTime @default(now())

  parent            Parent             @relation(fields: [parentId], references: [id], onDelete: Cascade)
  rawEvents         RawEvent[]
  cognitiveProfile  CognitiveProfile?

  @@index([parentId])
}

model RawEvent {
  id        String       @id @default(cuid())
  childId   String
  eventType RawEventType
  payload   Json
  createdAt DateTime     @default(now())

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, createdAt])
  @@index([eventType])
}

model CognitiveProfile {
  id                     String   @id @default(cuid())
  childId                String   @unique
  numberSenseScore       Float    @default(0)
  spatialScore           Float    @default(0)
  logicScore             Float    @default(0)
  strategyScore          Float    @default(0)
  latestDiagnosisSummary String?
  updatedAt              DateTime @updatedAt

  child Child @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
}
